# Aurrin Ventures Platform - Environment Configuration
# Copy this to .env.local and fill in your actual values

# ============================================================================
# Supabase Configuration
# ============================================================================
# Get these from your Supabase project settings

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_JWT_SECRET=your-jwt-secret-here

# Database connection string (optional, for direct access)
DATABASE_URL=postgresql://postgres:password@your-project.supabase.co:5432/postgres

# ============================================================================
# Stripe Configuration
# ============================================================================
# Get these from https://dashboard.stripe.com/apikeys

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ============================================================================
# Resend Email Configuration
# ============================================================================
# Get your API key from https://resend.com

RESEND_API_KEY=re_...

# ============================================================================
# Feature Flags
# ============================================================================

NEXT_PUBLIC_ENABLE_SCORING=true
NEXT_PUBLIC_ENABLE_AUDIENCE_VALIDATION=true
NEXT_PUBLIC_ENABLE_MENTOR_MATCHING=false
NEXT_PUBLIC_ENABLE_COMMERCE=false

# ============================================================================
# Observability & Logging
# ============================================================================

LOG_LEVEL=info
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_ANALYTICS_ID=

# ============================================================================
# Application Settings
# ============================================================================

# Session/JWT expiration (seconds)
JWT_EXPIRATION=86400

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# File upload limits
MAX_FILE_SIZE_MB=50
ALLOWED_FILE_TYPES=.pdf,.pptx,.ppt,.xlsx,.jpg,.png

# Audience validation
AUDIENCE_SESSION_TTL_HOURS=24
AUDIENCE_RATE_LIMIT_PER_SESSION=10

# Email
FROM_EMAIL=noreply@aurrin.ventures
REPLY_TO_EMAIL=support@aurrin.ventures
